# --- Data ---
# Raw Europarl corpus (~600 MB): CANNOT be committed, GitHub rejects files >100 MB.
# Task 1 regenerates everything from it; teammates do not need it (see README).
it-en/
*.tgz
*.tar.gz

# Ignore data/ by default...
data/
# ...but DO commit the gzipped 10% sample (~20 MB) + the sample indices,
# so a fresh clone can run Tasks 2-5 without downloading the corpus.
!data/
!data/sample/
!data/sample/sample.en.gz
!data/sample/sample.it.gz
!data/sample/sample_idx.npy
# Keep the uncompressed copies out (60 MB, regenerated by gunzip).
data/sample/sample.en
data/sample/sample.it

# --- Model checkpoints / large artifacts ---
checkpoints/
*.pt
*.pth
*.ckpt
*.bin

# --- Python / Jupyter ---
.venv/
venv/
__pycache__/
*.pyc
.ipynb_checkpoints/

# --- OS / editor cruft ---
.DS_Store
.idea/
.vscode/

# Note: results/ (small figures + CSVs) is intentionally tracked - part of the report deliverable.
